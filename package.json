  "description": "MCP server for Loxone Miniserver — expose smart-home rooms, controls, and commands to Claude and other AI assistants via the Model Context Protocol",
  "keywords": [
    "mcp",
    "loxone",
    "miniserver",
    "smart-home",
    "home-automation",
    "ai"
  ],
  "license": "MIT",
  "author": "kamil-bidus <kamil@syntropicsignal.ai>",
  "homepage": "https://syntropicsignal.ai",
  "bugs": {
    "email": "bugs@syntropicsignal.ai",
    "url": "https://github.com/syntropicsignal-ai/loxone-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntropicsignal-ai/loxone-mcp.git"
  },
  "type": "module",
  "bin": {
    "loxone-mcp": "dist/index.js"
  },
  "files": [
