# Loxone Miniserver connection
# Option A – Loxone Cloud Connect (recommended for remote/cloud deployments)
LOXONE_SERIAL=XXXXXXXXXXXX   # 12-char serial from Miniserver settings
# Option B – Direct LAN access (no cloud dependency)
# LOXONE_HOST=192.168.1.100  # IP or hostname of your Miniserver (not yet implemented — PRs welcome)

LOXONE_USER=admin
LOXONE_PASS=yourpassword

# MCP server
PORT=3000
MCP_API_KEY=changeme         # Use: openssl rand -hex 32
